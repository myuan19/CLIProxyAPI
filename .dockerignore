# Git and GitHub folders
.git/*
.github/*

# Docker and CI/CD related files
docker-compose.yml
.dockerignore
.gitignore
.goreleaser.yml
Dockerfile

# Documentation and license
docs/*
README.md
README_CN.md
LICENSE

# Runtime data folders (should be mounted as volumes)
auths/*
logs/*
conv/*
config.yaml
config.test.yaml
config.*.yaml
!config.example.yaml
pgstore/*
gitstore/*
objectstore/*
temp/*
refs/*

# Development/editor
bin/*
.vscode/*
.claude/*
.codex/*
.gemini/*
.serena/*
.agent/*
.agents/*
.opencode/*
.bmad/*
_bmad/*
_bmad-output/*

# Environment and dev artifacts (prevent leaking secrets into build context)
.env
.env.*
!.env.example
.DEV/logs
.DEV/config.test.yaml
.DEV/docs
.DEV/experiments
.DEV/static/*
!.DEV/static/management.html

# Hook scripts — runtime artifacts contain secrets (tokens, proxy pools, state)
hook-scripts/**/output/
hook-scripts/**/.venv/
hook-scripts/**/config.json
hook-scripts/**/.rotation_state

# Logs, experiments, references, notes, scripts (not needed in image)
_logs/
_experiments/
_reference/
_notes/
_docs/
_scripts/
!_scripts/.tmp/static/management.html
_AGENT/

# Credentials
**/credentials.json
**/.adc_credentials.json
